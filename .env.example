# ─── Admin Dashboard Environment Variables ──────────────────────────────────

# WhatsApp — Meta Cloud API (Free tier)
NEXT_PUBLIC_WA_PHONE_ID=your_phone_number_id
WA_TOKEN=your_whatsapp_bearer_token

# Razorpay (Sandbox mode)
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_secret

# Fast2SMS — SMS fallback (India, free tier 50 SMS/day)
FAST2SMS_API_KEY=your_key

# Base URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase (already configured)
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend — Email notifications (optional)
# RESEND_API_KEY=your_resend_key

# Upstash Redis (optional — for cache)
# UPSTASH_REDIS_REST_URL=your_url
# UPSTASH_REDIS_REST_TOKEN=your_token
