# ─────────────────────────────────────────────────────────────────
# Sweta Fashion Points — Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# For production: add these in Vercel → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── MSG91 SMS (OTP delivery) ──────────────────────────────────────
# Step 1: Create account at https://msg91.com
# Step 2: Get Auth Key from MSG91 → Settings → API Keys
MSG91_AUTH_KEY=your-msg91-auth-key

# Step 3: Register Sender ID on DLT portal (mandatory in India)
#   - Go to your telecom operator DLT portal (Airtel/Vodafone/BSNL/Jio)
#   - Register Entity (your company)
#   - Register Sender ID (6 chars, e.g. SWEFPT)
MSG91_SENDER_ID=SWEFPT

# Step 4: Register OTP template on DLT portal
#   Template example: "Your OTP for login at Fashion Points is ##OTP##. Valid for 10 minutes."
#   After DLT approval, add the template in MSG91 → SMS → OTP → Templates
#   Copy the Template ID shown in MSG91 dashboard
MSG91_TEMPLATE_ID=your-msg91-otp-template-id

# ── Resend (Email) ────────────────────────────────────────────────
# Get API key from https://resend.com → API Keys
RESEND_API_KEY=re_your-resend-api-key

# ── Razorpay (Payments) ───────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your-key-id

# ── Cloudinary (Product Images) ──────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Gupshup (WhatsApp — optional) ────────────────────────────────
GUPSHUP_API_KEY=your-gupshup-api-key
GUPSHUP_APP_NAME=FashionPoints
GUPSHUP_SOURCE_NUMBER=91xxxxxxxxxx
